# PORT for running backend express server
PORT=5000

# Set to true to bypass Firebase auth and use mock roles/users in frontend development
DEMO_MODE=true

# Gemini API key (for primary Q&A, translations, and alerts generation)
GEMINI_API_KEY=your_gemini_api_key_here

# Groq API key (for fallback LLM tasks)
GROQ_API_KEY=your_groq_api_key_here

# Firebase Admin SDK Configuration (Used when DEMO_MODE=false)
# NEVER commit a file containing actual private keys to source control!
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=your_firebase_client_email
# Private key should contain the newlines properly structured
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Permitted Client Host for Cross-Origin Resource Sharing (CORS)
ALLOWED_ORIGIN=http://localhost:5173
